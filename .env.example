# Supabase — Shop backend. Copy to .env and fill with your project's values
# (Supabase dashboard → Project Settings → API). Both are safe to expose to the
# browser (the anon key is public); Row Level Security governs access.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
